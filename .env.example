# qmtquant environment variables (template)
#
# Copy this file to `.env` ONLY once you need live trading:
#     cp .env.example .env
#
# NOTE: the backtest path needs NONE of these. The default synthetic backtest
# (`qmtquant` CLI / run_backtest) runs with zero configuration. These variables
# are placeholders for the FUTURE live-trading path via xtquant / miniQMT, which
# becomes available after QMT trading qualification is obtained.

# --- Live trading (post-qualification; currently unused) ---------------------

# Your QMT / xtquant stock account id.
# Uncomment and fill in after qualification:
# QMTQUANT_XT_ACCOUNT_ID=

# Filesystem path to the miniQMT installation (the userdata_mini directory that
# xtquant.xttrader connects to). Uncomment and fill in after qualification:
# QMTQUANT_MINI_QMT_PATH=
