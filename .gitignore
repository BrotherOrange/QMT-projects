# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Packaging / build artifacts
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Generated backtest outputs
# (the stray root-level backtrader_plot.png is exactly the smell we prevent:
#  plots belong in artifacts/ and must never be committed)
artifacts/
*.png

# Environment / secrets
.env
.venv/
venv/

# IDE
.idea/
.vscode/
